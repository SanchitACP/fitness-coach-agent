# Copy this file to .env and fill in your real values.
# .env is gitignored and must never be committed.

# API key for the LLM backend. The agent runs Claude inside Google ADK via
# LiteLLM, which reads this variable name. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=your_key_here

# OAuth token for the Google Calendar MCP (Phase 2, optional).
GOOGLE_CALENDAR_TOKEN=your_token_here
